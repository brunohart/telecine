---
import Base from '../../layouts/Base.astro';
import network from '../../data/network.json';

export function getStaticPaths() {
  return Object.values(network.films).map((film) => ({ params: { slug: film.slug }, props: { film } }));
}
const { film } = Astro.props;
const ch = network.channels.find((c) => c.id === film.channel);
const mins = Math.round(film.durationSec / 60);
---

<Base title={`${film.title} (${film.year}) — Telecine`} description={film.logline}>
  <article class="wrap film">
    <div class="wash wash-signal" style="width: 38vw; height: 30vh; right: -12vw; top: 4rem;" aria-hidden="true"></div>
    <p style="margin-top:1.4rem">
      <span class="stamp">Programme notes</span>
      <a class="mono-label ch-link" href={`/channels/${ch.id}`} style="margin-left:.7rem">CH {ch.number} — {ch.name}</a>
    </p>
    <h1 class="page-title film-title ghost" data-text={film.title} data-settle="0">{film.title}</h1>
    <p class="film-meta" data-settle="60">
      {film.year} · Directed by {film.director} · {mins} minutes
    </p>

    <p class="logline" data-settle="120">{film.logline}</p>

    <div class="note prose" data-settle="180">
      <p>{film.note}</p>
    </div>

    <aside class="airings offset-ink tilt-c" data-settle="240">
      <h2 class="mono-label">Next transmissions · your local time</h2>
      <ol id="airings" data-slug={film.slug} data-channel={ch.id}></ol>
      <p class="airing-note">
        There is no play button. <em>{film.title}</em> screens when the channel screens it —
        tune in on <a href={`/#${ch.number}`}>CH {ch.number}</a> or catch it at the next time above.
      </p>
    </aside>

    <footer class="provenance">
      <hr class="rule-broken" />
      <p>
        <span class="mono-label">The print</span><br />
        Transmitted from a public-domain print held by the Internet Archive
        (<a href={film.itemUrl}>{film.identifier}</a>). Public-domain films belong to everyone;
        if you love this one, the Archive accepts <a href="https://archive.org/donate">donations</a>
        toward keeping the shelves open.
      </p>
    </footer>
  </article>

  <script>
    import network from '../../data/network.json';
    import { airingsBetween, loopDuration, resolve } from '../../lib/broadcast.js';

    const list = document.getElementById('airings');
    const ch = network.channels.find((c) => c.id === list.dataset.channel);
    const slug = list.dataset.slug;
    const now = Date.now();
    const fmt = new Intl.DateTimeFormat(undefined, { weekday: 'short', hour: 'numeric', minute: '2-digit' });

    const r = resolve(ch, now);
    if (r.block.type === 'film' && r.block.film === slug) {
      const li = document.createElement('li');
      li.className = 'on-air';
      li.innerHTML = `<span class="a-time">ON AIR NOW</span> <span>${Math.floor(r.offsetSec / 60)} minutes in — <a href="/#${ch.number}">tune in</a></span>`;
      list.append(li);
    }
    const horizon = now + 3 * loopDuration(ch) * 1000;
    airingsBetween(ch, now, horizon)
      .filter((a) => a.block.film === slug)
      .slice(0, 3)
      .forEach((a, i) => {
        const li = document.createElement('li');
        li.innerHTML = `<span class="a-time">${fmt.format(a.start)}</span><span class="a-note">${i === 0 ? 'next screening' : ''}</span>`;
        list.append(li);
      });
  </script>
</Base>

<style>
  .film { position: relative; }
  .ch-link { text-decoration: none; }
  .ch-link:hover { color: var(--ink); }
  .film-title { font-style: italic; }
  .film-meta { color: var(--ink-soft); }
  .logline { margin-top: 1.6rem; font-family: var(--display); font-size: 1.3rem; font-weight: 600; line-height: 1.35; max-width: 30ch; }
  .note { margin-top: 1.4rem; font-size: 1.02rem; }

  .airings { margin-top: 2.6rem; padding: 1.2rem 1.3rem 1.3rem; background: var(--card); border: 1px solid var(--line); border-radius: 6px; max-width: 32rem; }
  .airings ol { list-style: none; margin: .7rem 0 0; padding: 0; }
  .airings li { display: flex; gap: .9rem; align-items: baseline; padding: .45rem 0; border-bottom: 1px solid var(--line); font-size: .92rem; }
  .airings li:last-of-type { border-bottom: 0; }
  :global(.a-time) { font-family: var(--mono); font-size: .74rem; letter-spacing: .06em; color: var(--ink); min-width: 8.5rem; }
  :global(.a-note) { font-size: .8rem; font-style: italic; color: var(--ink-faint); }
  .airings :global(li.on-air .a-time) { color: var(--live); }
  .airing-note { margin-top: .8rem; font-size: .84rem; color: var(--ink-soft); }

  .provenance { margin-top: 2.8rem; max-width: 62ch; }
  .provenance p { margin-top: 1rem; font-size: .88rem; color: var(--ink-soft); }
</style>
